# proxy.env.example — copy to proxy.env (repo root) and fill in credentials.
# proxy.env is gitignored and will never be committed.
#
# Honored by pip, git (HTTPS), huggingface_hub, curl.
# Set http_proxy AND https_proxy to the same HTTP proxy URL.

export http_proxy="http://USER:PASS@proxy.host:port"
export https_proxy="http://USER:PASS@proxy.host:port"
export no_proxy="localhost,127.0.0.1"
export HF_TOKEN="xxx"

# conda env to activate (must already exist, with a CUDA-enabled torch).
# export CONDA_ENV="doll"

# Optional: override default paths if you didn't clone this repo under your
# code directory (defaults are ../TripoSplat for code and ../../model/<Name> for
# weights — models live one dir above <code-dir>, shared by all algorithms).
# export TRIPOSPLAT_DIR=/path/to/code/TripoSplat
# export MODEL_DIR=/path/to/model/TripoSplat

# --- SSL: CERTIFICATE_VERIFY_FAILED behind a TLS-intercepting proxy? ---
# The scripts auto-point pip/hf/git at /etc/ssl/certs/ca-certificates.crt and
# add pip --trusted-host. If the corporate root CA is NOT in that system bundle,
# hf download / git clone will still fail. Extract the proxy's CA and append it:
#   echo | openssl s_client -connect huggingface.co:443 -proxy <proxy-host>:<port> -showcerts 2>/dev/null | openssl x509 > /tmp/proxy_ca.pem
#   cat /etc/ssl/certs/ca-certificates.crt /tmp/proxy_ca.pem > ~/.ca-bundle.crt
#   export REQUESTS_CA_BUNDLE=~/.ca-bundle.crt
#   export SSL_CERT_FILE=~/.ca-bundle.crt
#   export GIT_SSL_CAINFO=~/.ca-bundle.crt
